<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>攻略サイト風ポートフォリオ</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f5f6f7;
    }

    header {
      background: #2c3e50;
      color: white;
      padding: 15px;
      font-size: 20px;
    }

    .container {
      display: flex;
    }

    /* サイドバー */
    .sidebar {
      width: 250px;
      background: #34495e;
      color: white;
      min-height: 100vh;
      padding: 15px;
    }

    .sidebar h2 {
      font-size: 16px;
      border-bottom: 1px solid #7f8c8d;
      padding-bottom: 5px;
    }

    .sidebar a {
      display: block;
      color: #ecf0f1;
      text-decoration: none;
      padding: 8px 0;
    }

    .sidebar a:hover {
      background: #3d566e;
    }

    /* メイン */
    .main {
      flex: 1;
      padding: 20px;
    }

    .card {
      background: white;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 5px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    table th, table td {
      border: 1px solid #ccc;
      padding: 8px;
      text-align: left;
    }

    table th {
      background: #ecf0f1;
    }

    footer {
      background: #2c3e50;
      color: white;
      text-align: center;
      padding: 10px;
    }
  </style>
</head>
<body>

<header>
  攻略サイト風ポートフォリオ
</header>

<div class="container">
  
  <!-- サイドバー -->
  <div class="sidebar">
    <h2>メニュー</h2>
    <a href="#">トップ</a>
    <a href="#">キャラクター一覧</a>
    <a href="#">ストーリー</a>
    <a href="#">データベース</a>
    <a href="#">お問い合わせ</a>
  </div>

  <!-- メインコンテンツ -->
  <div class="main">

    <div class="card">
      <h2>お知らせ</h2>
      <p>このサイトはポートフォリオ用に作成した攻略サイト風デザインです。</p>
    </div>

    <div class="card">
      <h2>最新更新</h2>
      <ul>
        <li>キャラクター追加（仮）</li>
        <li>ページデザイン更新</li>
        <li>UI改善</li>
      </ul>
    </div>

    <div class="card">
      <h2>サンプルキャラクター</h2>
      <table>
        <tr>
          <th>名前</th>
          <th>レア度</th>
          <th>役割</th>
        </tr>
        <tr>
          <td>サンプルA</td>
          <td>★★★★★</td>
          <td>アタッカー</td>
        </tr>
        <tr>
          <td>サンプルB</td>
          <td>★★★★</td>
          <td>サポーター</td>
        </tr>
      </table>
    </div>

  </div>
</div>

<footer>
  © 2026 Portfolio
</footer>

</body>
</html>
